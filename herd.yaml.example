# Herd Configuration Example (v1.1.0)
# Copy to herd.yaml and customize for your cluster.
#
# Herd supports three backend types per node:
#   - "ollama" (default) — talks to Ollama's HTTP API
#   - "llama-server" — talks to llama.cpp's llama-server via OpenAI-compatible API
#   - "openai-compat" — talks to any OpenAI-compatible endpoint
#
# NOTE: The following keys were removed in v0.4.3 and are silently ignored:
#   - backends[].default_model  -> use backends[].hot_models instead
#   - routing.idle_timeout_minutes  -> use model_warmer.interval_secs instead
# If present, Herd logs a warning but does not error.

# === SERVER ===

server:
  host: "0.0.0.0"               # Listen address (default: 0.0.0.0)
  port: 40114                    # Listen port (default: 40114)
  api_key: "your-secret-key"    # Required for admin API endpoints (/admin/*)
  rate_limit: 0                  # Global requests/sec limit; 0 = unlimited
                                 # (legacy — prefer rate_limiting.global below)

# === RATE LIMITING ===
# Per-client rate limiting with API key mapping.
# Off by default (global: 0 = unlimited, no clients).
# Clients are identified by API key from Authorization: Bearer or X-Api-Key headers.
# Response headers: X-Herd-RateLimit-Limit, X-Herd-RateLimit-Remaining, X-Herd-RateLimit-Reset

# rate_limiting:
#   global: 100          # requests/sec for unauthenticated/unknown clients (0 = unlimited)
#   clients:
#     - name: my-agent
#       api_key: sk-agent-12345
#       rate_limit: 50   # requests/sec for this client
#     - name: dashboard
#       api_key: sk-dash-67890
#       rate_limit: 200
#     - name: vip-client
#       api_key: sk-vip-99999
#       rate_limit: 0    # 0 = unlimited for this client

# === ROUTING ===

routing:
  strategy: "model_aware"        # Routing algorithm: priority | model_aware | least_busy | weighted_round_robin | scored
  timeout: "120s"                # Per-request timeout for backend calls (supports s, ms, m, h)
  retry_count: 2                 # Retries on backend failure before returning an error
  default_keep_alive: "-1"       # Injected into every /api/generate and /api/chat request body.
                                 # "-1" = never unload; "5m" = 5 minutes; "0" = unload immediately.
                                 # Overrides whatever the client sent. Not injected on /v1/* paths.

  # === SCORED ROUTING ===
  # The `scored` strategy (strategy: "scored") ranks eligible backends by a weighted,
  # multi-dimensional score (GATE eliminates unhealthy/excluded/model-absent backends,
  # then SCORE ranks the rest) instead of a single axis. Dimensions with no available
  # source for a given backend drop out neutrally (never a penalty). Omit the block to
  # use the defaults below. A weight of 0 disables that dimension.
  #
  # scored:
  #   model_gate: "relaxed"          # "relaxed" (fall back to healthy set if a model is
  #                                  # loaded nowhere) or "strict" (503 instead)
  #   weights:
  #     model_resident: 5.0          # prefer backends with the requested model loaded
  #     model_fits_vram: 2.0         # prefer backends with VRAM headroom for the model
  #     prompt_size_vs_capacity: 1.0 # prefer windows that fit the prompt (needs max_context_len)
  #     gpu_utilization: 3.0         # prefer idle GPUs (needs gpu metrics)
  #     vram_headroom: 2.0           # prefer more free VRAM (gpu-metrics derived)
  #     gpu_temperature: 1.0         # prefer cooler GPUs
  #     operator_priority: 2.0       # honor the per-backend `priority` field
  #     tag_affinity: 1.0            # prefer backends matching requested X-Herd-Tags
  #     backend_type_affinity: 0.0   # prefer a backend type (off by default)
  #     queue_depth: 2.0             # prefer shorter request queues (agent telemetry)
  #     ttft_p50: 3.0                # prefer faster time-to-first-token (not yet measured)
  #     concurrency_saturation: 1.0  # prefer backends with free concurrency slots (agent telemetry)
  #     precise_vram_free: 2.0       # prefer more measured free VRAM (agent telemetry)

  # === AUTO MODE ===
  # LLM-based request classification. When model is "auto" or omitted, Herd calls
  # a small local model to classify the request, then routes to the best model.
  # Off by default — zero overhead when disabled.

  # auto:
  #   enabled: false
  #   classifier_model: "qwen3:1.7b"       # Small local model for classification
  #   classifier_timeout_ms: 3000           # Max time for the classification call
  #   fallback_model: "qwen2.5-coder:32b"  # Used when classifier fails or times out
  #   cache_ttl_secs: 60                    # Cache classification results by message hash
  #   model_map:
  #     light:
  #       general: "qwen3:1.7b"
  #       code: "qwen2.5-coder:7b"
  #     standard:
  #       general: "qwen3:8b"
  #       code: "qwen2.5-coder:32b"
  #       reasoning: "qwen3:32b"
  #     heavy:
  #       general: "qwen3:32b"
  #       code: "qwen2.5-coder:32b"
  #     frontier:
  #       _provider: "true"                 # Signals: route to frontier gateway (future)
  #       general: "claude-sonnet-4-20250514"
  #       reasoning: "claude-opus-4-20250514"

# === ROUTING PROFILES ===
# Named routing presets. Clients select via X-Herd-Profile header.
# Off by default — when disabled, global routing config is used for all requests.

# routing_profiles:
#   enabled: false
#   default_profile: balanced
#   profiles:
#     fast:
#       strategy: priority
#       description: "Fastest response — routes to highest-priority backend"
#     balanced:
#       strategy: least_busy
#       description: "Balanced load across all backends"
#     gpu-only:
#       strategy: model_aware
#       tags: [gpu]
#       description: "Route only to GPU-tagged backends"
#     local:
#       strategy: priority
#       backends: [local-ollama]
#       description: "Route only to local Ollama instance"
#     coding:
#       strategy: model_aware
#       preferred_model: "qwen2.5-coder:32b"
#       tags: [gpu, high-vram]
#       description: "Coding tasks — prefers large coding model on GPU backends"

# === MODEL WARMER ===
# Replaces the old model_homing block from v0.4.2.
# Sends keep_alive pings to hot_models on each backend to prevent Ollama's
# default 5-minute eviction. Also pre-loads hot_models on startup.

model_warmer:
  interval_secs: 240             # Seconds between keep-alive pings (default: 240, min: 10).
                                 # Must be shorter than Ollama's eviction window (default 5 min).
  timeout_secs: 180              # Per-model timeout for warming requests (default: 180).
                                 # Large models (20GB+) may need 60-180s to load into VRAM.

# ── Task Classifier ────────────────────────────────────────────────
# Automatically classify requests by complexity when no model is specified.
# Off by default — zero overhead when disabled.
#
# task_classifier:
#   enabled: false
#   strategy: "keyword"              # Only "keyword" supported for now
#   default_tier: "standard"         # Tier used when no keywords match
#   tiers:
#     heavy:
#       keywords: ["analyze", "architect", "debug complex", "design system", "reason about", "compare tradeoffs", "explain why", "review this code"]
#       model: "qwen2.5:32b-instruct"
#     standard:
#       keywords: ["summarize", "generate", "write function", "convert", "create template", "format"]
#       model: "qwen2.5:14b-instruct"
#     lightweight:
#       keywords: ["heartbeat", "ping", "status", "hello", "lookup", "define", "quick check"]
#       model: "llama3.2:3b"

# === BACKENDS ===

backends:
  - name: "citadel-5090"         # Unique name shown in dashboard and logs
    url: "http://citadel:11434"  # Ollama API base URL (required)
    priority: 100                # Higher = preferred; used by priority and weighted_round_robin strategies
    gpu_hot_url: "http://citadel:1312"  # gpu-hot endpoint for real-time GPU metrics (optional)
    tags:                        # Tags for X-Herd-Tags header routing (optional)
      - "local"
      - "gpu"
      - "high-vram"
    hot_models:                  # Models to keep permanently loaded on this backend (optional)
      - "qwen2.5-coder:32b"     # Must include the tag (e.g. :latest, :32b)
      - "glm-4.7-flash:latest"
    health_check_path: "/api/version"  # Custom health-check path (default: /api/version)
    # health_check_status: 200   # Expected HTTP status for health checks (default: 200)
    # max_context_len: 32768     # Context-window size (tokens) this backend serves.
                                 # Feeds the `scored` router's prompt_size_vs_capacity
                                 # dimension (prefers backends whose window fits the
                                 # prompt). Omit to leave that dimension neutral.

  - name: "minipc-4080"
    url: "http://100.81.153.82:11434"
    priority: 80
    gpu_hot_url: "http://100.81.153.82:1312"
    tags:
      - "local"
      - "gpu"
      - "medium-vram"

  - name: "warden-4070"
    url: "http://100.106.188.105:11434"
    priority: 50
    model_filter: "≤8B"          # Only route models matching this filter to this backend.
                                 # This is a literal string parsed by Herd — "≤8B" means
                                 # "only models with parameter count <= 8 billion".
                                 # You can also use a regex pattern like "qwen|llama" to match
                                 # model names. The ≤/≥ prefix syntax is specific to size filtering.
    tags:
      - "local"
      - "gpu"
      - "low-vram"

  # llama-server backend example (llama.cpp):
  # llama-server backends use OpenAI-compatible endpoints for health checks (/health)
  # and model discovery (/v1/models). hot_models is ignored (model set at server start).
  # Use herd-tune --backend llama-server to set up and register automatically.
  #
  # - name: "citadel-llama"
  #   url: "http://citadel:8090"      # llama-server listen address
  #   backend: "llama-server"          # Backend type: "ollama" (default), "llama-server", or "openai-compat"
  #   priority: 100
  #   tags:
  #     - "gpu"
  #     - "high-vram"
  #   max_context_len: 32768           # ctx window served (tokens); feeds the scored
  #                                    # router's prompt_size_vs_capacity dimension
  #   # health_check_path defaults to /health for llama-server (vs /api/version for ollama)
  #   # Model discovery uses /v1/models instead of /api/tags

  # OpenAI-compatible backend example:
  # Any server exposing OpenAI-compatible /v1/chat/completions and /v1/models endpoints.
  #
  # - name: "external-openai"
  #   url: "http://my-server:8080"
  #   backend: "openai-compat"
  #   priority: 50
  #   tags:
  #     - "external"
  #   # health_check_path defaults to /v1/models for openai-compat backends

# === DISCOVERY ===
# Multi-node fleet discovery. Automatically probes and registers remote Herd nodes.
# Off by default — zero overhead when disabled.
#
# discovery:
#   enabled: false
#   probe_interval_secs: 60          # How often to re-probe static nodes (default: 60, min: 10)
#   static_nodes:
#     - url: http://192.168.1.100:8090
#       backend: llama-server        # Backend type: ollama (default), llama-server, openai-compat
#       tags: [gpu, nvidia]
#       priority: 10
#     - url: http://192.168.1.101:11434
#       backend: ollama
#       hostname: minipc             # Optional hostname override (default: extracted from URL)
#       tags: [gpu]
#   mdns:
#     enabled: false                 # Requires building with --features mdns (not yet implemented)
#     service_name: "_herd._tcp.local."
#     broadcast: true
#     listen: true

# === TLS ===
# Optional HTTPS support. Off by default. Requires building with --features tls.
# Falls back to HTTP gracefully if cert/key files are missing or malformed.
#
# tls:
#   enabled: false
#   cert_path: /path/to/cert.pem
#   key_path: /path/to/key.pem
#   redirect_http: false            # Spawn a second listener that 301-redirects HTTP → HTTPS
#   redirect_port: 80               # Port for the HTTP redirect listener (default: 80)

# === BUDGET CAPS ===
# Track estimated API-equivalent cost and enforce per-client/per-model limits.
# Off by default — zero overhead when disabled. Costs are estimated from token
# counts using tiered pricing (see analytics.rs estimate_api_cost).
# Clients are identified via the X-Herd-Client header.
#
# budget:
#   enabled: false
#   global_limit_usd: 50.00         # Total spend cap across all clients/models (0 = unlimited)
#   reset_period: monthly            # daily, weekly, monthly
#   action: reject                   # reject (429) or warn (log + allow)
#   clients:
#     agent-team: 20.00
#     dashboard: 5.00
#   models:
#     "llama3:70b": 30.00

# === CIRCUIT BREAKER ===
# Automatically stops routing to failing backends and probes them for recovery.

circuit_breaker:
  failure_threshold: 3           # Consecutive failures before marking backend unhealthy (default: 5)
  timeout: "30s"                 # Timeout for health-check probes (default: 120s)
  recovery_time: "60s"           # Wait time before probing an unhealthy backend (default: 30s)
                                 # Should be greater than timeout for effective recovery

# === OBSERVABILITY ===

observability:
  metrics: true                  # Enable /metrics endpoint (Prometheus format) (default: true)
  admin_api: true                # Enable /admin/* management endpoints (default: false)
  tracing: false                 # Enable debug tracing output (default: false)
  log_retention_days: 7          # Auto-prune JSONL request logs older than N days (default: 7)
  log_max_size_mb: 100           # Rotate log file when it exceeds N MB (default: 100, 0 = no limit)
  log_max_files: 5               # Keep up to N rotated log files (default: 5)

# === AGENT ===
# Built-in agent session management with tool calling and permission controls.
# Off by default. Requires api_key to be set.

# agent:
#   enabled: false
#   max_sessions: 100               # Maximum concurrent agent sessions
#   max_tool_rounds: 10             # Max tool-call iterations per message
#   session_ttl_minutes: 60         # Auto-expire idle sessions after this duration
#   permissions:
#     allow_shell_commands: false    # Enable run_command tool (default: false)
#     deny_file_patterns:           # Regex patterns blocking file access
#       - "\.env$"
#       - "\.ssh/"
#     deny_bash_patterns:           # Regex patterns blocking shell commands
#       - "^rm\\s+-rf"
#       - "^sudo"

# === FRONTIER GATEWAY ===
# Route requests to cloud LLM providers when local models can't handle the task.
# Off by default — frontier routing never activates by accident.
# API keys are read from environment variables, never stored in config.

# frontier:
#   enabled: false
#   allow_auto_escalation: false   # let auto mode route to frontier when local can't handle
#   require_header: true           # requests must include X-Herd-Frontier: true
#   log_all_requests: true         # JSONL audit log for every frontier request
#   warn_threshold: 0.80           # warn at 80% of monthly budget
#   block_threshold: 1.00          # hard block at 100%

# === PROVIDERS ===
# Cloud LLM providers for frontier routing. Each needs an env var with the API key.

# providers:
#   - name: "anthropic"
#     api_url: "https://api.anthropic.com/v1"
#     api_key_env: "ANTHROPIC_API_KEY"
#     models: ["claude-opus-4-20250514", "claude-sonnet-4-20250514"]
#     rate_limit: 50               # requests per minute
#     monthly_budget: 100.00       # USD hard cap
#     priority: 50
#
#   - name: "openai"
#     api_url: "https://api.openai.com/v1"
#     api_key_env: "OPENAI_API_KEY"
#     models: ["gpt-4.1", "o4-mini"]
#     rate_limit: 60
#     monthly_budget: 50.00
#     priority: 40
#
#   - name: "xai"
#     api_url: "https://api.x.ai/v1"
#     api_key_env: "XAI_API_KEY"
#     models: ["grok-3", "grok-3-mini"]
#     rate_limit: 30
#     monthly_budget: 30.00
#     priority: 30
#
#   - name: "openrouter"
#     api_url: "https://openrouter.ai/api/v1"
#     api_key_env: "OPENROUTER_API_KEY"
#     models: []                   # empty = accept any model, proxy through
#     rate_limit: 100
#     monthly_budget: 50.00
#     priority: 20

# === FLEET MANAGEMENT ===
# Agent self-update: herd agent daemons running on each node heartbeat the gateway
# every ~2s and self-update when the gateway advertises a newer published binary.
# All fields optional — defaults work out of the box (gateway serves its own version).
#
# Operator promote workflow:
#   1. cargo build --release
#   2. herd publish ./target/release/herd --version 1.2.0
#      (prints the sha256 the gateway will advertise)
#   3. Set fleet.target_agent_version: "1.2.0" in herd.yaml (supports hot-reload —
#      POST /admin/reload or wait for the 30s file-watcher cycle; no restart needed)
#   4. Agents self-update on their next heartbeat (~2s); old binary is evicted after
#      the grace period

# fleet:
#   target_agent_version: "1.2.0"          # version agents self-update to;
#                                           # env HERD_TARGET_AGENT_VERSION wins;
#                                           # defaults to the gateway's own version
#   publish_dir: "~/.herd/binaries"        # where published agent binaries live;
#                                           # env HERD_AGENT_PUBLISH_DIR wins;
#                                           # default: ~/.herd/binaries
#   download_url_base: "https://cdn.example.com/herd"
#                                           # OPTIONAL external download source;
#                                           # unset = gateway serves binaries itself
#   respawn_mode: "self"                   # fleet-wide restart intent: self | supervised
